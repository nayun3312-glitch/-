{
  "name": "instagram-analyzer",
  "version": "1.0.0",
  "description": "Apify 기반 Instagram 인플루언서 분석기 (백엔드)",
  "main": "server.js",
  "scripts": {
    "setup": "npm install && npm --prefix client install",
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server.js",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client install && npm --prefix client run build",
    "start": "node server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
